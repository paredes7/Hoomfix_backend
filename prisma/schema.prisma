generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum ProviderStatus {
  PENDING  // Postulación enviada, esperando revisión del admin
  APPROVED // Admin aprobó — puede recibir trabajos
  REJECTED // Admin rechazó los documentos
}

enum ServiceStatus {
  SEARCHING   // Cliente solicitó, buscando provider disponible
  ASSIGNED    // Provider aceptó el trabajo
  ON_WAY      // Provider va en camino al domicilio
  IN_PROGRESS // Provider está realizando el trabajo
  COMPLETED   // Trabajo finalizado
  CANCELLED   // Servicio cancelado por cliente o provider
}

enum MessageType {
  TEXT  // Mensaje de texto plano
  IMAGE // URL de imagen enviada en el chat
  AUDIO // URL de nota de voz enviada en el chat
}

enum CallType {
  VOICE // Llamada de voz
  VIDEO // Videollamada
}

enum CallStatus {
  INITIATED // Llamada iniciada, esperando respuesta
  ACCEPTED  // Receptor aceptó la llamada
  REJECTED  // Receptor rechazó la llamada
  ENDED     // Llamada terminada normalmente
  MISSED    // No fue atendida
}

enum RechargeStatus {
  PENDING  // Solicitud enviada, esperando aprobación del admin
  APPROVED // Admin aprobó — saldo acreditado
  REJECTED // Admin rechazó la solicitud
}

enum WithdrawalStatus {
  PENDING  // Solicitud enviada, esperando aprobación del admin
  APPROVED // Admin aprobó — saldo debitado del ProviderWallet
  REJECTED // Admin rechazó el retiro
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

/// Catálogo de países. El admin agrega o desactiva países desde el panel.
/// Cada país define su código ISO, código de marcado y moneda local.
model Country {
  iso       String   @id             // Código ISO del país (ej: BO, US, PE)
  dialCode  String                   // Código de marcado telefónico (ej: +591, +1)
  name      String                   // Nombre del país (ej: Bolivia)
  currency  String                   // Moneda local (ej: BOB, USD, PEN)
  active    Boolean  @default(true)  // false = no aparece en el combo box del frontend
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles         Profile[]         // Country (1) → (N) Profile: un país puede tener muchos usuarios registrados
  providerServices ProviderService[] // Country (1) → (N) ProviderService: un país tiene muchas especialidades de providers registradas

  @@map("Country") // Evita conflicto con la palabra reservada "Country" de Prisma  
}

/// Configuración global del sistema. Solo existe UN registro.
/// El admin ajusta la comisión de la plataforma y límite de trabajos simultáneos.
model SystemConfig {
  id                String   @id @default(uuid())
  commissionRate    Float    @default(0.15) // Porcentaje que cobra la plataforma por servicio (0.15 = 15%)
  maxConcurrentJobs Int      @default(2)    // Máximo de trabajos activos simultáneos por especialidad
  updatedAt         DateTime @updatedAt

  @@map("SystemConfig") // Evita conflicto con la palabra reservada "SystemConfig" de Prisma
}

/// Tipos de cambio para convertir paquetes de USD a la moneda local del cliente.
/// El admin actualiza las tasas desde el panel. Siempre fromCurrency = "USD".
model ExchangeRate {
  id           String   @id @default(uuid())
  fromCurrency String                   // Moneda origen (siempre "USD")
  toCurrency   String                   // Moneda destino (ej: "BOB", "PEN", "ARS")
  rate         Float                    // Tasa de conversión (ej: 6.96 para USD → BOB)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("ExchangeRate") // Evita conflicto con la palabra reservada "ExchangeRate" de Prisma
  @@unique([fromCurrency, toCurrency])
}

/// Catálogo de tipos de servicio (Gasfitería, Electricidad, etc.).
/// El admin crea y activa/desactiva categorías sin tocar el código.
model ServiceType {
  id          String   @id @default(uuid())
  name        String   @unique             // Nombre único de la categoría (ej: "Gasfitería")
  icon        String?                      // URL o nombre del ícono para mostrar en la app
  description String?                      // Descripción breve del tipo de servicio
  active      Boolean  @default(true)      // false = no aparece en la app para nuevos servicios
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  providerServices ProviderService[] // ServiceType (1) → (N) ProviderService: una categoría puede tener muchos providers registrados
  services         Service[]         // ServiceType (1) → (N) Service: una categoría puede tener muchos servicios solicitados

  @@map("ServiceType") // Evita conflicto con la palabra reservada "ServiceType" de Prisma
}

/// Modelo base solo para autenticación. Cualquier usuario (cliente, provider o admin) tiene un User.
/// Los datos personales viven en ClientProfile o ProviderProfile según el rol.
model User {
  id                  String    @id @default(uuid())
  email               String?   @unique  // Correo para iniciar sesión — opcional si se registra con teléfono
  phone               String?   @unique  // Teléfono para iniciar sesión (ej: +59170012345) — opcional si se registra con email
  username            String    @unique  // Elegido por el usuario al registrarse — solo letras y números
  password            String             // Hash bcrypt de la contraseña
  isActive            Boolean   @default(true)    // false = cuenta bloqueada por el admin
  expoPushToken       String?            // Token de Expo para enviar notificaciones push al dispositivo del usuario
  resetPasswordToken  String?            // Hash del código de recuperación de contraseña
  resetPasswordExpiry DateTime?          // Fecha de expiración del código de recuperación
  isOnboardingCompleted Boolean   @default(false)    // true = completó el onboarding inicial
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  profile          Profile?          // User (1) → (1) Profile: datos personales y wallet del usuario
  providerServices ProviderService[] // User (1) → (N) ProviderService: especialidades en las que el usuario actúa como provider
  sentMessages     Message[]         @relation("SentMessages")   // User (1) → (N) Message: mensajes enviados en los chats de sus servicios
  clientServices   Service[]         @relation("ClientServices") // User (1) → (N) Service: servicios solicitados si es CLIENT
  ratings          Rating[]          @relation("ClientRatings")  // User (1) → (N) Rating: calificaciones dadas a providers si es CLIENT
  historyViews     HistoryView[]       // User (1) → (N) HistoryView: historial de historias vistas por el usuario
  savedProviders   SavedProvider[]    @relation("SavedProviders") // User (1) → (N) SavedProvider: providers guardados como favoritos
  postLikes        PostLike[]        // User (1) → (N) PostLike: likes dados a publicaciones de providers
  postComments     PostComment[]     // User (1) → (N) PostComment: comentarios escritos en publicaciones de providers
  reelLikes        ReelLike[]        // User (1) → (N) ReelLike: likes dados a reels de providers
  reelComments     ReelComment[]     // User (1) → (N) ReelComment: comentarios escritos en reels de providers
  savedBy          SavedPost[]      // User (1) → (N) SavedPost: publicaciones guardadas como favoritas por el usuario
  followers        Follow[]         @relation("Following") // User (1) → (N) Follow: usuarios que siguen a este provider
  following        Follow[]         @relation("Follower")  // User (1) → (N) Follow: providers que este usuario sigue
  admin            Admin?                                  // User (1) → (0-1) Admin: si existe, el usuario es administrador

  @@map("User") // Evita conflicto con la palabra reservada "User" de Prisma
}

/// Tabla de administradores. Un User es admin solo si tiene un registro aquí.
/// Para dar acceso de admin: crear un Admin con userId. Para quitarlo: eliminar el registro.
model Admin {
  id        String   @id @default(uuid())
  userId    String   @unique   // FK a User — un user solo puede ser admin una vez
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id]) // Admin (1) → (1) User: este admin es un user del sistema

  @@map("Admin")
}


/// Datos personales del cliente. Se crea automáticamente al registrarse como CLIENT.
/// Tiene su propio Wallet para pagar servicios.
model Profile {
  id              String    @id @default(uuid())
  userId          String    @unique
  countryIso      String              // FK a Country — define la moneda del Wallet. Se elige al registrarse y no cambia.
  firstName       String?             // Nombre del cliente
  lastName        String?             // Apellido del cliente
  avatar          String?             // URL pública de la foto de perfil en Cloudinary
  avatarPublicId  String?             // public_id de Cloudinary para poder reemplazar o eliminar la imagen
  referralCode    String?   @unique   // Código único para referir a otros usuarios
  lastLoginAt     DateTime?           // Último inicio de sesión
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  wallet   Wallet?   // Profile (1) → (1) Wallet: billetera del usuario para pagar servicios
  contacts Contact[] // Profile (1) → (N) Contact: números de contacto del usuario (máx 3)
  user     User      @relation(fields: [userId],     references: [id])  // Profile (N) → (1) User: este perfil pertenece a un solo usuario
  country  Country   @relation(fields: [countryIso], references: [iso]) // Profile (N) → (1) Country: define la moneda del wallet

  @@map("Profile") // Evita conflicto con la palabra reservada "Profile" de Prisma
}

/// Números de contacto del cliente. Un cliente puede tener múltiples números.
/// Separado de ClientProfile para permitir varios registros por cliente.
model Contact {
  id        String   @id @default(uuid())
  profileId String             // FK a Profile — número pertenece a un solo usuario
  phone     String   @unique   // Número de teléfono único en toda la plataforma
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id]) // Contact (N) → (1) Profile: este número pertenece a un solo usuario
  
  @@map("Contact") // Evita conflicto con la palabra reservada "Contact" de Prisma  
}

/// Números de contacto del provider por especialidad. Una especialidad puede tener múltiples números.
/// Separado de ProviderService para permitir varios registros por especialidad.
model ProviderContact {
  id                String   @id @default(uuid())
  providerServiceId String             // Especialidad a la que pertenece este número
  phone             String   @unique   // Número de teléfono único en la plataforma
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  providerService ProviderService @relation(fields: [providerServiceId], references: [id]) // ProviderContact (N) → (1) ProviderService: este número pertenece a una sola especialidad

  @@map("ProviderContact") // Evita conflicto con la palabra reservada "Contact" de Prisma
}

/// Representa una especialidad del provider. Un provider puede tener múltiples registros,
/// uno por cada tipo de servicio en el que está habilitado (Gasfitería, Electricidad, etc.).
/// Cada uno tiene su propio estado de verificación, calificación y ProviderWallet de ganancias.
/// @@unique([userId, serviceTypeId]) evita que el mismo provider se postule dos veces a la misma especialidad.
model ProviderService {
  id              String         @id @default(uuid())
  userId        String                            // Provider al que pertenece esta especialidad
  serviceTypeId String                            // Tipo de servicio (Gasfitería, Electricidad, etc.)
  countryIso    String                            // FK a Country — define la moneda del ProviderWallet y el dialCode. Se elige al postularse y no cambia.
  status              ProviderStatus @default(PENDING)  // Estado de verificación del admin
  submittedForReview  Boolean        @default(false)    // true = el provider ya mandó sus documentos a revisión
  available           Boolean        @default(false)    // true = disponible para recibir nuevos trabajos
  rating          Float          @default(0)        // Promedio de calificaciones (0.0 a 5.0)
  totalRatings    Int            @default(0)         // Cantidad total de calificaciones recibidas
  latitude        Float?                            // Ubicación actual — para encontrar el provider más cercano
  longitude       Float?                            // Ubicación actual
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user           User                    @relation(fields: [userId], references: [id])           // ProviderService (N) → (1) User: esta especialidad pertenece a un solo provider
  serviceType    ServiceType             @relation(fields: [serviceTypeId], references: [id])    // ProviderService (N) → (1) ServiceType: esta especialidad pertenece a una sola categoría
  country        Country                 @relation(fields: [countryIso], references: [iso])      // ProviderService (N) → (1) Country: define la moneda del ProviderWallet y el dialCode
  providerWallet ProviderWallet?                                                                 // ProviderService (1) → (1) ProviderWallet: cada especialidad tiene su propia billetera de ganancias
  profile        ProviderServiceProfile?                                                         // ProviderService (1) → (1) ProviderServiceProfile: cada especialidad tiene su propio perfil de presentación
  documents        ProviderDocument[]                                                              // ProviderService (1) → (N) ProviderDocument: una especialidad puede tener muchos documentos de verificación
  services         Service[]             @relation("ProviderServices")                           // ProviderService (1) → (N) Service: una especialidad puede atender muchos servicios
  providerContacts ProviderContact[]    
  histories        History[]                                                              // ProviderService (1) → (N) History: una especialidad puede tener múltiples historias
  savedBy          SavedProvider[]                                                        // ProviderService (1) → (N) SavedProvider: usuarios que guardaron esta especialidad como favorito
  posts            Post[]                                                                // ProviderService (1) → (N) Post: una especialidad puede tener muchas publicaciones para mostrar su trabajo
  reels            Reel[]                                                                // ProviderService (1) → (N) Reel: una especialidad puede tener muchos reels para mostrar su trabajo
  anuncios         Anuncio[]                                                             // ProviderService (1) → (N) Anuncio: una especialidad puede tener muchos anuncios pagados

  @@unique([userId, serviceTypeId])

  @@map("ProviderService") // Evita conflicto con la palabra reservada "Service" de Prisma
}

/// Perfil de presentación de una especialidad del provider.
/// Contiene los datos editables que el cliente ve: foto, nombre personalizado, bio, etc.
/// Se crea al postularse y puede editarse libremente después.
model ProviderServiceProfile {
  id                   String   @id @default(uuid())
  providerServiceId    String   @unique             // Especialidad dueña de este perfil (1 a 1)
  bio                  String?                      // Descripción profesional para esta especialidad
  experience           Int?                         // Años de experiencia en esta especialidad
  coverageRadius       Float?                       // Radio máximo de cobertura en kilómetros
  commercialName       String?                      // Nombre del negocio o marca (opcional)
  customServiceName    String?                      // Nombre personalizado del servicio (ej: "Plomería Express")
  contactEmail         String?                      // Correo de contacto para este servicio (puede diferir del email de la cuenta)
  servicePhoto         String?                      // URL pública de la foto del servicio en Cloudinary
  servicePhotoPublicId String?                      // public_id de Cloudinary para reemplazar o eliminar la foto
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  providerService ProviderService @relation(fields: [providerServiceId], references: [id]) // ProviderServiceProfile (1) → (1) ProviderService: este perfil de presentación pertenece a una sola especialidad

  @@map("ProviderServiceProfile") // Evita conflicto con la palabra reservada "Profile" de Prisma
}

model Post {
  id                String    @id @default(uuid())
  providerServiceId String                    // Publicación ligada a la especialidad
  content           String?                   // Texto de la publicación
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  providerService ProviderService @relation(fields: [providerServiceId], references: [id]) // Post (N) → (1) ProviderService: esta publicación pertenece a una sola especialidad
  media           PostMedia[]     // Post (1) → (N) PostMedia: una publicación puede tener varias fotos o videos (carrusel)
  likes           PostLike[]      // Post (1) → (N) PostLike: una publicación puede tener muchos likes de clientes
  comments        PostComment[]   // Post (1) → (N) PostComment: una publicación puede tener muchos comentarios de clientes
  savedPosts       SavedPost[]     // Post (1) → (N) SavedPost: una publicación puede ser guardada por muchos clientes como favorita

  @@map("Post") // Evita conflicto con la palabra reservada "Post" de Prisma
}

model PostMedia {
  id            String    @id @default(uuid())
  postId        String
  mediaUrl      String    // URL Cloudinary del media (foto o video) para mostrar en la publicación
  mediaPublicId String    // Para eliminar de Cloudinary
  mediaType     MediaType // IMAGE o VIDEO
  order         Int       // Orden de las fotos (como carrusel)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  post Post @relation(fields: [postId], references: [id]) // PostMedia (N) → (1) Post: este media pertenece a una sola publicación

  @@map("PostMedia") // Evita conflicto con la palabra reservada "Media" de Prisma
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   // usuario que sigue
  followingId String   // usuario al que sigue (el provider)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  follower  User @relation("Follower",  fields: [followerId],  references: [id]) // Follow (N) → (1) User: este follow fue hecho por un solo usuario
  following User @relation("Following", fields: [followingId], references: [id]) // Follow (N) → (1) User: este follow es hacia un solo usuario

  @@unique([followerId, followingId])
  @@map("Follow") // Evita conflicto con la palabra reservada "Follow" de Prisma
}


model PostLike {
  id        String   @id @default(uuid())
  postId    String   // Publicación que recibió el like
  userId    String   // Usuario que dio el like (debe ser cliente)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id]) // PostLike (N) → (1) Post: este like pertenece a una sola publicación
  user User @relation(fields: [userId], references: [id]) // PostLike (N) → (1) User: este like fue realizado por un solo usuario

  @@map("PostLike") // Evita conflicto con la palabra reservada "Like" de Prisma
  @@unique([postId, userId]) // Un like por usuario
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String   // Publicación a la que pertenece el comentario
  userId    String   // Usuario que escribió el comentario (debe ser cliente)
  content   String   // Texto del comentario
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id]) // PostComment (N) → (1) Post: este comentario pertenece a una sola publicación
  user User @relation(fields: [userId], references: [id]) // PostComment (N) → (1) User: este comentario fue escrito por un solo usuario

  @@map("PostComment") // Evita conflicto con la palabra reservada "Comment" de Prisma
}

// Tabla intermedia para guardar las publicaciones favoritas de cada cliente. Un cliente puede guardar varias publicaciones como favoritas, y una publicación puede ser guardada por varios clientes. La combinación userId + postId es única para evitar duplicados.
model SavedPost {
  id        String   @id @default(uuid())
  userId    String                      // Usuario que guardó la publicación
  postId    String                      // Publicación guardada
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])  // SavedPost (N) → (1) User: este favorito fue guardado por un solo usuario
  post Post @relation(fields: [postId], references: [id])  // SavedPost (N) → (1) Post: este favorito es de una sola publicación

  @@unique([userId, postId]) // No puede guardar la misma publicación dos veces

  @@map("SavedPost") // Evita conflicto con la palabra reservada "SavedPost" de Prisma
}

// Tabla intermedia para guardar los providers favoritos de cada cliente. Un cliente puede guardar varias especialidades como favoritas, y una especialidad puede ser guardada por varios clientes. La combinación clientId + providerServiceId es única para evitar duplicados.
model SavedProvider {
  id        String   @id @default(uuid())
  clientId  String             // Cliente que guardó este provider
  providerServiceId String      // Especialidad del provider que se guardó
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client          User             @relation("SavedProviders", fields: [clientId], references: [id])           // SavedProvider (N) → (1) User: este favorito fue guardado por un solo cliente
  providerService ProviderService @relation(fields: [providerServiceId], references: [id]) // SavedProvider (N) → (1) ProviderService: este favorito es de una sola especialidad

  @@map("SavedProvider") // Evita conflicto con la palabra reservada "SavedProvider" de Prisma
  @@unique([clientId, providerServiceId]) // Evita que el mismo cliente guarde la misma especialidad varias veces
}

/// Historia que el provider sube para mostrar su trabajo a los clientes.
/// Expira automáticamente a las 24 horas. El cron job elimina las expiradas.
model History {
  id                String    @id @default(uuid())
  providerServiceId String                       // Especialidad a la que pertenece esta historia
  mediaUrl          String                       // URL pública del media en Cloudinary
  mediaPublicId     String                       // public_id de Cloudinary para eliminar al expirar
  mediaType         MediaType @default(IMAGE)    // Tipo de media (IMAGE o VIDEO)
  caption           String?                      // Texto opcional sobre la historia
  expiresAt         DateTime                     // createdAt + 24h — el cron job elimina las expiradas
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  historyViews HistoryView[] // History (1) → (N) HistoryView: una historia puede tener muchas vistas de clientes
  providerService ProviderService @relation(fields: [providerServiceId], references: [id]) // History (N) → (1) ProviderService: esta historia pertenece a una sola especialidad

  @@map("History") // Evita conflicto con la palabra reservada "History" de Prisma
}

// Registro de cada vez que un cliente ve una historia de un provider. Sirve para mostrar el conteo de vistas y evitar contar varias vistas del mismo usuario.
model HistoryView {
  id        String   @id @default(uuid())
  historyId String             // Historia que se vio
  userId    String             // Usuario que vio la historia
  viewedAt  DateTime @default(now()) // Momento en que se vio la historia

  history History @relation(fields: [historyId], references: [id]) // HistoryView (N) → (1) History: esta vista pertenece a una sola historia
  user    User    @relation(fields: [userId], references: [id])    // HistoryView (N) → (1) User: esta vista fue hecha por un solo usuario

  @@unique([historyId, userId]) // Evita que el mismo usuario cuente varias veces como vista de la misma historia
  @@map("HistoryView") // Evita conflicto con la palabra reservada "View" de Prisma
}

/// Reel corto del provider para mostrar su trabajo (estilo TikTok/Instagram Reels).
/// Independiente de Post — es contenido vertical corto con su propia sección en la app.
model Reel {
  id                String   @id @default(uuid())
  providerServiceId String                      // Especialidad a la que pertenece este reel
  videoUrl          String                      // URL Cloudinary del video
  videoPublicId     String                      // public_id para eliminar de Cloudinary
  thumbnailUrl      String                      // URL Cloudinary del thumbnail (primer frame)
  thumbnailPublicId String                      // public_id del thumbnail para eliminar
  caption           String?                     // Texto opcional sobre el reel
  duration          Int                         // Duración en segundos (máx 60)
  views             Int      @default(0)        // Contador de reproducciones
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  providerService ProviderService @relation(fields: [providerServiceId], references: [id]) // Reel (N) → (1) ProviderService: este reel pertenece a una sola especialidad
  likes           ReelLike[] // Reel (1) → (N) ReelLike: un reel puede tener muchos likes de clientes
  comments        ReelComment[]  // Reel (1) → (N) ReelComment: un reel puede tener muchos comentarios de clientes

  @@map("Reel") // Evita conflicto con la palabra reservada "Reel" de Prisma  
}

model ReelLike {
  id        String   @id @default(uuid())
  reelId    String  // Reel que recibió el like
  userId    String  // Usuario que dio el like (debe ser cliente)
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id]) // ReelLike (N) → (1) Reel: este like pertenece a un solo reel
  user User @relation(fields: [userId], references: [id])    // ReelLike (N) → (1) User: este like fue dado por un solo usuario

  @@unique([reelId, userId]) // Evita que el mismo usuario le dé like al mismo reel varias veces
  @@map("ReelLike") // Evita conflicto con la palabra reservada "Like" de Prisma
}

model ReelComment {
  id        String   @id @default(uuid())
  reelId    String   // Reel al que pertenece el comentario
  userId    String   // Usuario que escribió el comentario (debe ser cliente)
  content   String   // Texto del comentario
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reel Reel @relation(fields: [reelId], references: [id]) // ReelComment (N) → (1) Reel: este comentario pertenece a un solo reel
  user User @relation(fields: [userId], references: [id]) // ReelComment (N) → (1) User: este comentario fue escrito por un solo usuario

  @@map("ReelComment") // Evita conflicto con la palabra reservada "Comment" de Prisma
}

/// Anuncio pagado por el provider para destacar su especialidad en los resultados de búsqueda.
/// El saldo se descuenta del ProviderWallet al crear el anuncio (prepago).
model Anuncio {
  id                String   @id @default(uuid())
  providerWalletId  String                       // Wallet de donde se descontó el saldo
  providerServiceId String                       // Especialidad que se está promocionando
  title             String                       // Título del anuncio (ej: "Electricista profesional en La Paz")
  description       String?                      // Texto descriptivo del anuncio
  mediaUrl         String?                      // URL de imagen opcional para mostrar en el anuncio
  mediaPublicId    String?                      // public_id de Cloudinary para eliminar o reemplazar
  mediaType       MediaType?                   // Tipo de media (IMAGE o VIDEO) para el anuncio
  budget            Float                        // Saldo descontado del ProviderWallet al crear
  startDate         DateTime                     // Fecha de inicio del anuncio
  endDate           DateTime                     // Fecha de fin — el cron job lo desactiva automáticamente
  active            Boolean  @default(true)      // false = expirado o desactivado manualmente
  impressions       Int      @default(0)         // Veces que se mostró en búsquedas
  clicks            Int      @default(0)         // Veces que tocaron el anuncio
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  providerWallet  ProviderWallet  @relation(fields: [providerWalletId],  references: [id])  // Anuncio (N) → (1) ProviderWallet: el saldo se descontó de esta billetera
  providerService ProviderService @relation(fields: [providerServiceId], references: [id])  // Anuncio (N) → (1) ProviderService: esta especialidad es la que se promociona

  @@map("Anuncio") // Evita conflicto con la palabra reservada "Ad" de Prisma
}

/// Documento o certificado subido por el provider para verificar una especialidad.
/// Cada documento se guarda por separado para poder eliminarlo o reemplazarlo individualmente.
model ProviderDocument {
  id                String   @id @default(uuid())
  providerServiceId String             // Especialidad a la que pertenece este documento
  url               String             // URL pública del documento en Cloudinary
  publicId          String             // public_id de Cloudinary para eliminar o reemplazar
  name              String?            // Nombre descriptivo (ej: "Certificado de electricista")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  providerService ProviderService @relation(fields: [providerServiceId], references: [id]) // ProviderDocument (N) → (1) ProviderService: este documento pertenece a una sola especialidad
  @@map("ProviderDocument") // Evita conflicto con la palabra reservada "Document" de Prisma
}

/// Billetera del cliente. Solo para pagar servicios. Recibe recargas aprobadas por el admin.
/// La moneda se define según el país del cliente (BOB, USD, PEN, etc.).
model Wallet {
  id        String   @id @default(uuid())
  profileId String   @unique         // FK a Profile — billetera pertenece a un solo usuario
  currency  String                   // Moneda fija del wallet (ej: BOB, USD, PEN) — se asigna al registrarse y nunca cambia
  balance   Float    @default(0)     // Saldo disponible para pagar servicios
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile    @relation(fields: [profileId], references: [id]) // Wallet (1) → (1) Profile: esta billetera pertenece a un solo usuario
  recharges Recharge[]                                                   // Wallet (1) → (N) Recharge: historial de recargas de saldo
  
  @@map("Wallet") // Evita conflicto con la palabra reservada "Wallet" de Prisma
}

/// Billetera del provider por especialidad. Acumula ganancias de servicios completados.
/// La moneda se define según el país del provider para esa especialidad.
model ProviderWallet {
  id                String   @id @default(uuid())
  providerServiceId String   @unique     // Especialidad dueña de esta billetera
  currency          String               // Moneda fija del wallet (ej: BOB, USD, PEN) — se asigna al postularse y nunca cambia
  balance           Float    @default(0) // Ganancias acumuladas pendientes de retiro
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  providerService ProviderService   @relation(fields: [providerServiceId], references: [id]) // ProviderWallet (1) → (1) ProviderService: esta billetera pertenece a una sola especialidad
  withdrawals     Withdrawal[]                                                                // ProviderWallet (1) → (N) Withdrawal: una billetera puede tener muchos retiros en su historial
  purchases       ProviderPurchase[]                                                          // ProviderWallet (1) → (N) ProviderPurchase: una billetera puede tener muchas recargas compradas
  anuncios        Anuncio[]                                                                       // ProviderWallet (1) → (N) Anuncio: una billetera puede tener muchos anuncios pagados

  @@map("ProviderWallet") // Evita conflicto con la palabra reservada "Wallet" de Prisma
}

/// Paquetes de recarga que el admin crea. El cliente elige uno para recargar su wallet.
/// El precio base está en USD y se convierte automáticamente a la moneda del cliente usando ExchangeRate.
model Package {
  id        String   @id @default(uuid())
  name      String             // Nombre descriptivo del paquete (ej: "Paquete Básico", "Paquete Pro")
  amountUsd Float              // Precio base en USD (ej: 10.00). Se convierte a la moneda del usuario al acreditar.
  active    Boolean  @default(true)  // false = no aparece para los usuarios
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recharges         Recharge[]          // Package (1) → (N) Recharge: un paquete puede ser usado en muchas recargas de clientes
  providerPurchases ProviderPurchase[]   // Package (1) → (N) ProviderPurchase: un paquete puede ser comprado por muchos providers

  @@map("Package") // Evita conflicto con la palabra reservada "Package" de Prisma
}

/// Registro de cada recarga de saldo que hace un cliente.
/// Flujo: cliente elige Package → Recharge (PENDING) → admin aprueba → Wallet.balance += package.amountUsd × ExchangeRate.rate
model Recharge {
  id             String         @id @default(uuid())
  clientWalletId String                           // Wallet del cliente que recarga
  packageId      String                           // Paquete elegido por el cliente
  status         RechargeStatus @default(PENDING) // Estado de la recarga
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  clientWallet Wallet @relation(fields: [clientWalletId], references: [id]) // Recharge (N) → (1) Wallet: esta recarga acredita saldo a una sola billetera de cliente
  package      Package      @relation(fields: [packageId], references: [id])      // Recharge (N) → (1) Package: esta recarga usa un solo paquete como referencia de monto

  @@map("Recharge") // Evita conflicto con la palabra reservada "Recharge" de Prisma
}

/// Recarga de saldo del provider. El provider compra un paquete para acreditar
/// saldo en su ProviderWallet de una especialidad específica.
/// Flujo: provider elige Package → ProviderPurchase (PENDING) → admin aprueba → ProviderWallet.balance += package.amountUsd × ExchangeRate.rate
model ProviderPurchase {
  id               String         @id @default(uuid())
  providerWalletId String                           // Wallet del provider que recarga
  packageId        String                           // Paquete elegido por el provider
  status           RechargeStatus @default(PENDING) // Estado de la compra
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  providerWallet ProviderWallet @relation(fields: [providerWalletId], references: [id]) // ProviderPurchase (N) → (1) ProviderWallet: esta compra acredita saldo a una sola billetera de provider
  package        Package        @relation(fields: [packageId], references: [id])         // ProviderPurchase (N) → (1) Package: esta compra usa un solo paquete como referencia de monto

  @@map("ProviderPurchase") // Evita conflicto con la palabra reservada "Purchase" de Prisma
}

/// Solicitud de retiro de ganancias del provider.
/// El provider solicita retirar el saldo de una especialidad específica a su cuenta bancaria.
/// Flujo: provider solicita → Withdrawal (PENDING) → admin aprueba → ProviderWallet.balance -= amount
model Withdrawal {
  id               String           @id @default(uuid())
  providerWalletId String                              // Wallet de la especialidad de donde se retira
  amount           Float                               // Monto a retirar
  bankName         String?                             // Nombre del banco destino
  accountNumber    String?                             // Número de cuenta bancaria destino
  status           WithdrawalStatus @default(PENDING)  // Estado del retiro
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  providerWallet ProviderWallet @relation(fields: [providerWalletId], references: [id]) // Withdrawal (N) → (1) ProviderWallet: este retiro descuenta saldo de una sola billetera de provider

  @@map("Withdrawal") // Evita conflicto con la palabra reservada "Withdrawal" de Prisma
}

/// Núcleo del negocio. Representa un servicio solicitado por un cliente.
/// Conecta al cliente con un ProviderService específico.
/// Estados: SEARCHING → ASSIGNED → ON_WAY → IN_PROGRESS → COMPLETED | CANCELLED
model Service {
  id                String        @id @default(uuid())
  clientId          String                            // Cliente que solicitó el servicio
  providerServiceId String?                           // Especialidad asignada (null hasta que se asigne)
  serviceTypeId     String                            // Tipo de servicio solicitado
  description       String                            // Descripción del problema o trabajo a realizar
  address           String                            // Dirección donde se realiza el servicio
  latitude          Float                             // Coordenadas para mostrar en el mapa
  longitude         Float                             // Coordenadas para mostrar en el mapa
  status            ServiceStatus @default(SEARCHING) // Estado actual del servicio
  price             Float?                            // Precio acordado del servicio (null hasta que se acuerde)
  commission        Float?                            // Comisión cobrada por la plataforma (price * commissionRate)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  client          User             @relation("ClientServices", fields: [clientId], references: [id])           // Service (N) → (1) User: este servicio fue solicitado por un solo cliente
  providerService ProviderService? @relation("ProviderServices", fields: [providerServiceId], references: [id]) // Service (N) → (1) ProviderService: este servicio es atendido por una sola especialidad (null en SEARCHING)
  serviceType     ServiceType      @relation(fields: [serviceTypeId], references: [id])                         // Service (N) → (1) ServiceType: este servicio pertenece a una sola categoría
  messages        Message[]                                                                                      // Service (1) → (N) Message: un servicio puede tener muchos mensajes en su chat
  calls           Call[]                                                                                         // Service (1) → (N) Call: un servicio puede tener muchas llamadas
  rating          Rating?                                                                                        // Service (1) → (1) Rating: un servicio solo puede tener una calificación al finalizar

  @@map("Service") // Evita conflicto con la palabra reservada "Service" de Prisma
}

/// Mensajes del chat dentro de un servicio activo.
/// Cliente y provider se comunican a través de estos mensajes durante el servicio.
model Message {
  id        String      @id @default(uuid())
  serviceId String                      // Servicio al que pertenece este mensaje
  senderId  String                      // Usuario que envió el mensaje
  content   String                      // Texto del mensaje o URL del archivo (imagen/audio)
  type      MessageType @default(TEXT)  // Tipo de contenido del mensaje
  read      Boolean     @default(false) // true = el receptor ya lo leyó
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  service Service @relation(fields: [serviceId], references: [id])                 // Message (N) → (1) Service: este mensaje pertenece a un solo servicio
  sender  User    @relation("SentMessages", fields: [senderId], references: [id])  // Message (N) → (1) User: este mensaje fue enviado por un solo usuario

  @@map("Message") // Evita conflicto con la palabra reservada "Message" de Prisma
}

/// Registro de llamadas de voz o video entre cliente y provider durante un servicio.
model Call {
  id         String     @id @default(uuid())
  serviceId  String                          // Servicio en el contexto del cual ocurre la llamada
  callerId   String                          // Usuario que inició la llamada
  receiverId String                          // Usuario que recibe la llamada
  type       CallType                        // VOICE o VIDEO
  status     CallStatus @default(INITIATED)  // Estado actual de la llamada
  startedAt  DateTime?                       // Momento en que el receptor aceptó la llamada
  endedAt    DateTime?                       // Momento en que terminó la llamada
  duration   Int?                            // Duración en segundos (calculado al terminar)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  service Service @relation(fields: [serviceId], references: [id]) // Call (N) → (1) Service: esta llamada ocurrió dentro de un solo servicio
  
  @@map("Call") // Evita conflicto con la palabra reservada "Call" de Prisma
}

/// Calificación que el cliente da al provider después de completar un servicio.
/// Solo una calificación por servicio. Al crearse, se recalcula ProviderService.rating automáticamente.
model Rating {
  id        String   @id @default(uuid())
  serviceId String   @unique          // Un solo Rating por servicio
  clientId  String                    // Cliente que calificó
  score     Int                       // Puntuación del 1 al 5
  comment   String?                   // Comentario opcional del cliente
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id])                  // Rating (1) → (1) Service: esta calificación pertenece a un solo servicio
  client  User    @relation("ClientRatings", fields: [clientId], references: [id])  // Rating (N) → (1) User: esta calificación fue dada por un solo cliente

  @@map("Rating") // Evita conflicto con la palabra reservada "Rating" de Prisma
}

enum MediaType {
  IMAGE
  VIDEO
}